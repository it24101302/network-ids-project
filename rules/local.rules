# ==============================================================================
# Custom Snort Ruleset - Network Intrusion Detection Engineering
# Name: Dulwan A.G.B 
# Attacker Environment: Kali Linux ($EXTERNAL_NET)
# Target Environment: Ubuntu IDS Target ($HOME_NET)
# Revision: 1.0
# ==============================================================================

# Rule 1: Nmap ICMP Ping Sweep Detection
# MITRE ATT&CK: T1595.002 (Active Scanning: Vulnerability Scanning / Host Discovery)
# Description: Detects ICMP Echo Requests with payload size of 0 (typical for Nmap ping sweep -sP / -sn).
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"NID-ENGINEERING: Nmap ICMP Ping Sweep Detected"; dsize:0; itype:8; classtype:network-scan; priority:3; sid:1000001; rev:1;)

# Rule 2: SSH Brute Force Authentication Attempt
# MITRE ATT&CK: T1110.001 (Brute Force: Password Guessing)
# Description: Detects repeated SSH connection initiations on SSH port 22 matching SSH-2.0 banner exchanges.
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"NID-ENGINEERING: SSH Brute Force Connection Attempt"; flow:to_server,established; content:"SSH-2.0-"; fast_pattern; classtype:attempted-recon; priority:2; sid:1000002; rev:1;)

# Rule 3: FTP Brute Force / Failed Login Pattern
# MITRE ATT&CK: T1110 (Brute Force)
# Description: Detects FTP 530 Login incorrect response strings returning to attacker.
alert tcp $HOME_NET 21 -> $EXTERNAL_NET any (msg:"NID-ENGINEERING: FTP Authentication Failure (Possible Brute Force)"; flow:from_server,established; content:"530 Login incorrect"; fast_pattern; classtype:unsuccessful-user; priority:3; sid:1000003; rev:1;)

# Rule 4: TCP SYN Flood Attack (High Threshold / Anomaly)
# MITRE ATT&CK: T1498.001 (Network Denial of Service: Direct Volume Flood)
# Description: Flags TCP SYN packets without ACK flag set destined for web service port 80.
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"NID-ENGINEERING: TCP SYN Flood Attack Attempt"; flags:S; flow:stateless; classtype:attempted-dos; priority:1; sid:1000004; rev:1;)

# Rule 5: Metasploit Meterpreter Reverse HTTP Stager Artifact
# MITRE ATT&CK: T1071.001 (Application Layer Protocol: Web Protocols)
# Description: Identifies URI request patterns commonly generated by Metasploit reverse_http / reverse_https payloads.
alert tcp $EXTERNAL_NET any -> $HOME_NET 80,8080,4444 (msg:"NID-ENGINEERING: Metasploit HTTP Meterpreter Stager URI Request"; flow:to_server,established; content:"GET"; http_method; content:"/INITM"; fast_pattern; classtype:web-application-activity; priority:1; sid:1000005; rev:1;)

# Rule 6: Nmap TCP SYN Stealth Scan
# MITRE ATT&CK: T1046 (Network Service Discovery)
# Description: Identifies TCP SYN packets sent with window size 1024 or 2048 typical of Nmap SYN port scans (-sS).
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"NID-ENGINEERING: Nmap TCP Stealth SYN Scan Detected"; flags:S; window:1024; classtype:network-scan; priority:3; sid:1000006; rev:1;)

# Rule 7: VSFTPD v2.3.4 Backdoor Remote Command Execution Attempt
# MITRE ATT&CK: T1190 (Exploit Public-Facing Application)
# Description: Detects username string ending with ':)' sent to FTP server which triggers VSFTPD 2.3.4 backdoor shell on port 6200.
alert tcp $EXTERNAL_NET any -> $HOME_NET 21 (msg:"NID-ENGINEERING: VSFTPD v2.3.4 Backdoor Trigger Attempt"; flow:to_server,established; content:"USER "; nocase; content:":)"; distance:0; fast_pattern; classtype:attempted-admin; priority:1; sid:1000007; rev:1;)

# Rule 8: Samba trans2open Overflow Attack / Metasploit Shellcode Execution
# MITRE ATT&CK: T1210 (Exploitation of Remote Services)
# Description: Detects NOP sled (\x90 sequence) payload targeted at Samba SMB port 139/445.
alert tcp $EXTERNAL_NET any -> $HOME_NET 139,445 (msg:"NID-ENGINEERING: Samba trans2open Buffer Overflow Payload"; flow:to_server,established; content:"|90 90 90 90 90 90 90 90 90 90|"; fast_pattern; classtype:attempted-admin; priority:1; sid:1000008; rev:1;)

# Rule 9: SQL Injection Attack via HTTP GET Request
# MITRE ATT&CK: T1190 (Exploit Public-Facing Application)
# Description: Inspects HTTP GET request parameters for common SQL syntax exploitation signatures (' OR 1=1 / UNION SELECT).
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"NID-ENGINEERING: HTTP GET SQL Injection Attempt"; flow:to_server,established; content:"GET"; http_method; content:"' OR "; nocase; fast_pattern; classtype:web-application-attack; priority:2; sid:1000009; rev:1;)

# Rule 10: Path / Directory Traversal Attack via HTTP
# MITRE ATT&CK: T1083 (File and Directory Discovery) / T1190
# Description: Detects relative directory traversal sequences (../..) in HTTP URI requests.
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"NID-ENGINEERING: HTTP Directory Traversal Attempt"; flow:to_server,established; content:"../.."; fast_pattern; http_uri; classtype:web-application-attack; priority:2; sid:1000010; rev:1;)